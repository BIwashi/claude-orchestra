{
  "name": "claude-orchestra",
  "version": "1.2.0",
  "description": "Turn multiple Claude Code sessions into a live orchestra — background music reacts to your coding activity",
  "bin": {
    "claude-orchestra": "./bin/conductor.js"
  },
  "type": "module",
  "files": [
    ".claude-plugin/",
    "bin/",
    "lib/",
    "data/instruments.json",
    "data/tracks/demo/",
    "data/tracks/ode-to-joy/source.mid",
    "data/tracks/orpheus-underworld/README.md",
    "skills/",
    "hooks/",
    "docs/",
    "LICENSES-THIRD-PARTY.md",
    "LICENSE",
    "data/tracks/polovtsian-dances/source.mid",
    "data/tracks/polovtsian-dances/README.md",
    "data/tracks/new-world/source.mid",
    "data/tracks/new-world/README.md",
    "data/tracks/morning-mood/source.mid",
    "data/tracks/morning-mood/README.md",
    "commands/",
    "output-styles/"
  ],
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "audio",
    "music",
    "orchestra",
    "coding-music",
    "background-music",
    "developer-tools",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BIwashi/claude-orchestra.git"
  },
  "homepage": "https://github.com/BIwashi/claude-orchestra#readme",
  "bugs": {
    "url": "https://github.com/BIwashi/claude-orchestra/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "author": "BIwashi",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
