{
  "name": "claude-orchestra",
  "version": "1.0.0",
  "description": "Turn multiple Claude Code sessions into a live orchestra",
  "bin": {
    "claude-orchestra": "./bin/conductor.js"
  },
  "type": "module",
  "files": [
    ".claude-plugin/",
    "bin/",
    "lib/",
    "data/",
    "skills/",
    "hooks/",
    "docs/"
  ],
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "audio",
    "music",
    "orchestra"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BIwashi/claude-orchestra.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "author": "BIwashi",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
